{
  "name": "Drop",
  "description": "Warm coral-peach with sun and mint accents. Group-chat warmth, not charity-platform sterility, not blood-bank red.",
  "palette": {
    "coral": {
      "50":  "#FFF6F1",
      "100": "#FFE6D6",
      "200": "#FFC9A8",
      "300": "#FFA776",
      "400": "#FF8A52",
      "500": "#F86F37",
      "600": "#DB5A24",
      "700": "#B0481D",
      "800": "#8A3917",
      "900": "#6B2D12",
      "role": "primary",
      "usage": "Logo dot, primary buttons (600 bg + white text), links (600), text emphasis (700)"
    },
    "sun": {
      "100": "#FFF1C7",
      "300": "#F8D67A",
      "400": "#F2BE3D",
      "600": "#B7860C",
      "role": "secondary",
      "usage": "Logo dot, milestones, celebration accents, drop-day highlight"
    },
    "mint": {
      "100": "#DDF3E5",
      "400": "#5FCB95",
      "600": "#1F8F5C",

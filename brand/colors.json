      "usage": "Logo dot, success states, 'sent' pills, confirmed pledges"
    },
    "ink": {
      "900": "#1A1410",
      "700": "#3A322D",
      "500": "#6B6058",
      "400": "#8A8079",
      "200": "#D9D2CC",
      "100": "#EDE8E3",

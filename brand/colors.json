      "usage": "Body text (900/700), captions (500), borders (200/100). 400 is large-text only."
    },
    "surfaces": {
      "paper": "#FFFBF7",
      "cream": "#FFF6F1",
      "white": "#FFFFFF"
    },
    "status": {
      "success": "#1F8F5C",
      "warning": "#B7860C",
      "danger":  "#C8341F"
    }
  },
  "gradients": {
    "heroWash": ["#FFF6F1", "#FFFBF7"],
    "primaryButton": ["#FF8A52", "#DB5A24"],
    "dropDay": ["#F86F37", "#F2BE3D"]
  },
  "contrast_notes": {
    "body_text_on_white": ["ink-900", "ink-700", "ink-500", "coral-700", "coral-800", "coral-900", "mint-600", "sun-600", "status.success", "status.warning", "status.danger"],
    "ui_only_not_body":   ["coral-500", "coral-600", "ink-400"],
    "decorative_only":    ["coral-50..400", "sun-100..400", "mint-100..400"]
